typedef struct _WSLCSDKImageInformation
{
    char Image[WSLCSDK_MAX_IMAGE_NAME_LENGTH + 1];
    char Hash[256];
    char Digest[256];
    LONGLONG Size; // Matches Docker's int64 image size
    LONGLONG Created; // Unix timestamp
    char ParentId[256];
} WSLCSDKImageInformation;

typedef enum _WSLCSDKListImagesFlags
{
    WSLCSDKListImagesFlagsNone = 0,
    WSLCSDKListImagesFlagsAll = 1,     // Show all images (default hides intermediate images)
    WSLCSDKListImagesFlagsDigests = 2, // Include digest information
} WSLCSDKListImagesFlags;

cpp_quote("DEFINE_ENUM_FLAG_OPERATORS(WSLCSDKListImagesFlags);")

