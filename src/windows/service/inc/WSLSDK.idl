typedef enum _WSLCSDKContainerFlags
{
    WSLCSDKContainerFlagsNone = 0,
    WSLCSDKContainerFlagsRm = 1, // Delete the container when it exits.
    WSLCSDKContainerFlagsGpu = 2, // Enable GPU access.
    WSLCSDKContainerFlagsInit = 4, // Run the container under an init process.
    WSLCSDKContainerFlagsPublishAll = 8, // Publish all exposed ports.
} WSLCSDKContainerFlags;

