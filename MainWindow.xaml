<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WSLAMoviePlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WSLAMoviePlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WSLA Movie Player">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video Player -->
        <Grid Grid.Row="0" MinHeight="400">
            <MediaPlayerElement x:Name="MediaPlayerElement" 
                                AreTransportControlsEnabled="False"
                                Stretch="Uniform"/>

            <!-- Subtitles overlaid on video -->
            <StackPanel VerticalAlignment="Bottom" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                <!-- Native Subtitle -->
                <Border Background="#99000000" 
                        CornerRadius="6"
                        Padding="16,6"
                        HorizontalAlignment="Center"
                        Margin="0,2">
                    <TextBlock x:Name="NativeSubtitleText"
                               Text=""
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="800"/>
                </Border>

                <!-- Translated Subtitle -->
                <Border Background="#99000000" 
                        CornerRadius="6"
                        Padding="16,4"
                        HorizontalAlignment="Center"
                        Margin="0,2">
                    <TextBlock x:Name="TranslatedSubtitleText"
                               Text=""
                               Foreground="#FFD700"
                               FontSize="16"
                               FontStyle="Italic"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="800"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Time Label -->
        <TextBlock x:Name="TimeLabel"
                   Grid.Row="1"
                   Text="00:00 / 00:00"
                   HorizontalAlignment="Center"
                   Margin="0,5"
                   FontSize="14"/>

        <!-- Progress Slider with Coverage Visualization -->
        <Grid Grid.Row="2" Margin="10,5">
            <!-- Green coverage overlay behind slider -->
            <Canvas x:Name="CoverageCanvas"
                    Height="4"
                    VerticalAlignment="Center"/>
            
            <!-- Main slider -->
            <Slider x:Name="ProgressSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    IsThumbToolTipEnabled="True"
                    ValueChanged="ProgressSlider_ValueChanged"
                    PointerPressed="ProgressSlider_PointerPressed"
                    PointerReleased="ProgressSlider_PointerReleased"/>
        </Grid>

        <!-- Control Buttons -->
        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Open File Button -->
            <Button x:Name="OpenFileButton"
                    Grid.Column="0"
                    Click="OpenFileButton_Click"
                    Padding="15,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Folder"/>
                    <TextBlock Text="Open File" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Skip Back Button -->
            <Button x:Name="SkipBackButton"
                    Grid.Column="2"
                    Click="SkipBackButton_Click"
                    Padding="15,8"
                    Margin="5,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Previous"/>
                    <TextBlock Text="-15s" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Play/Pause Button -->
            <Button x:Name="PlayPauseButton"
                    Grid.Column="3"
                    Click="PlayPauseButton_Click"
                    IsEnabled="False"
                    Padding="20,8"
                    Margin="5,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play"/>
                    <TextBlock x:Name="PlayPauseLabel" Text="Play" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Skip Forward Button -->
            <Button x:Name="SkipForwardButton"
                    Grid.Column="4"
                    Click="SkipForwardButton_Click"
                    Padding="15,8"
                    Margin="5,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="+15s" VerticalAlignment="Center"/>
                    <SymbolIcon Symbol="Next"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4"
                Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" 
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Processing indicator (left side) -->
                <StackPanel x:Name="ProcessingIndicator"
                            Grid.Column="0"
                            Orientation="Horizontal" 
                            Spacing="6"
                            Visibility="Collapsed">
                    <ProgressRing IsActive="True" Width="16" Height="16"/>
                    <TextBlock x:Name="ProcessingText"
                               Text="Processing subtitles..."
                               Foreground="Orange"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection status (right side) -->
                <StackPanel Grid.Column="1" 
                            Orientation="Vertical" 
                            Spacing="2">
                    <!-- Container status -->
                    <StackPanel Orientation="Horizontal" 
                                Spacing="6">
                        <Ellipse x:Name="ContainerDot" 
                                 Width="10" Height="10" 
                                 Fill="Gray"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ContainerStatusText"
                                   Text="Container: Idle"
                                   FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Socket connection status -->
                    <StackPanel Orientation="Horizontal" 
                                Spacing="6">
                        <Ellipse x:Name="ConnectionDot" 
                                 Width="10" Height="10" 
                                 Fill="Red"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Disconnected"
                                   FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
